
# FastBlog 环境配置文件

# 说明：复制此文件为 .env 并根据实际情况修改配置项
# 注意：生产环境请务必修改所有默认密码和密钥
#
# 快速开始：
# 1. cp .env_example .env
# 2. 修改下面的配置项
# 3. 启动应用: python main.py

# ----------------------------------------------------------------------------
# 数据库配置（仅支持 PostgreSQL）
# ----------------------------------------------------------------------------
# PostgreSQL 连接信息
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=cardedai260701
DB_TABLE_PREFIX=

# 数据库连接池配置

DB_POOL_SIZE=20
DB_POOL_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=1800

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------
# 服务器地址
DOMAIN=http://localhost:9421

# 站点信息
TITLE=FastBlog
DESCRIPTION=A modern, fast blog platform
KEYWORDS=blog, fast, modern

# 安全配置
SECRET_KEY=dev-secret-key-do-not-use-in-production-1234567890
TIME_ZONE=Asia/Shanghai
ENVIRONMENT=development
DEBUG=True

# JWT 认证配置
JWT_EXPIRATION_DELTA=86400
REFRESH_TOKEN_EXPIRATION_DELTA=604800
JWT_SECRET_KEY=dev-jwt-secret-key-do-not-use-in-prod
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------------
# Redis 配置（缓存和会话存储）
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# 缓存 TTL 配置（秒）
CACHE_TTL_DEFAULT=600
CACHE_TTL_ARTICLES=3600
CACHE_TTL_USERS=1800

# ----------------------------------------------------------------------------
# 邮件配置（用于密码重置、通知等）
# ----------------------------------------------------------------------------
# Gmail 示例
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# QQ 邮箱示例






# 163 邮箱示例






MAIL_FROM=noreply@fastblog.com
MAIL_FROM_NAME=FastBlog

# ----------------------------------------------------------------------------
# 文件存储配置
# ----------------------------------------------------------------------------
# 上传限制
UPLOAD_LIMIT=62914560
USER_FREE_STORAGE_LIMIT=536870912

# FFmpeg 配置（视频处理）
# Windows: 下载 ffmpeg.exe 并设置路径，例如: C:/ffmpeg/bin/ffmpeg.exe
# Linux: sudo apt-get install ffmpeg (通常已经在 PATH 中)
# macOS: brew install ffmpeg (通常已经在 PATH 中)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# S3/对象存储配置（从0.3.6.5版本后为必选）
# 支持的提供商：AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO 等
S3_ENABLED=False
S3_ENDPOINT_URL=



S3_REGION=us-east-1
S3_USE_SSL=True
S3_SIGNATURE_VERSION=s3v4

# CDN 配置（可选）
CDN_ENABLED=False
CDN_URL=https://cdn.yourdomain.com

# ----------------------------------------------------------------------------
# 备案信息（中国大陆服务器必填）
# ----------------------------------------------------------------------------
BEIAN=京ICP备12345678号
BEIAN_LINK=https://beian.miit.gov.cn/

# ----------------------------------------------------------------------------
# CORS 配置
# ----------------------------------------------------------------------------
# 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# 生产环境示例：


# ----------------------------------------------------------------------------
# 日志配置
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# ----------------------------------------------------------------------------
# 性能优化配置
# ----------------------------------------------------------------------------
# 文章列表每页默认数量
ARTICLES_PER_PAGE=10

# 搜索结果每页数量
SEARCH_RESULTS_PER_PAGE=20

# 评论每页数量
COMMENTS_PER_PAGE=50

# API 速率限制
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ----------------------------------------------------------------------------
# SEO 配置
# ----------------------------------------------------------------------------
# Google Analytics
GOOGLE_ANALYTICS_ID=

# Google Search Console
GOOGLE_SITE_VERIFICATION=

# Baidu Analytics
BAIDU_ANALYTICS_ID=

# Social Media
FACEBOOK_APP_ID=
TWITTER_CARD_TYPE=summary_large_image

# ----------------------------------------------------------------------------
# 第三方服务集成
# ----------------------------------------------------------------------------
# Sentry 错误追踪
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# OpenAI API（AI 功能）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Slack 通知
SLACK_WEBHOOK_URL=

# Discord 通知
DISCORD_WEBHOOK_URL=

# SendGrid 邮件服务
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# Mailgun 邮件服务
MAILGUN_API_KEY=
MAILGUN_DOMAIN=example.com
MAILGUN_FROM_EMAIL=noreply@example.com

# SMTP 邮件服务
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=user@example.com
EMAIL_PASSWORD=password
EMAIL_FROM=noreply@example.com
EMAIL_TO=admin@example.com,editor@example.com

# Stripe 支付
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal 支付
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----------------------------------------------------------------------------
# 开发工具配置
# ----------------------------------------------------------------------------
# Swagger UI 配置
SWAGGER_UI_ENABLED=True
SWAGGER_UI_PATH=/docs

# ReDoc 配置
REDOC_ENABLED=True
REDOC_PATH=/redoc

# ----------------------------------------------------------------------------
# 其他配置
# ----------------------------------------------------------------------------
# 是否启用注册
ALLOW_REGISTRATION=True

# 是否需要邮箱验证
EMAIL_VERIFICATION_REQUIRED=False

# 默认语言
DEFAULT_LOCALE=zh_CN

# 支持的语言列表（逗号分隔）
SUPPORTED_LOCALES=zh_CN,en_US,ja_JP,ko_KR

# 维护模式
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=网站正在维护中，请稍后访问